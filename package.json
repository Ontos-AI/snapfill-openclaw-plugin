{
  "name": "@snapfill/openclaw-plugin",
  "version": "0.1.6",
  "description": "SnapFill tools for OpenClaw",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "skills",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && echo '{\"type\":\"commonjs\"}' > dist-test/package.json && node dist-test/tests/run-tests.js",
    "prepublishOnly": "npm run check && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
