{
  "name": "@ontos-ai/snapfill-claw",
  "version": "0.2.1",
  "description": "SnapFill tools for OpenClaw",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "tsc -p tsconfig.test.json && echo '{\"type\":\"commonjs\"}' > dist-test/package.json && node dist-test/tests/run-tests.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run test"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "openclaw": "^2026.3.23-2",
    "typescript": "^5.8.2"
  }
}
