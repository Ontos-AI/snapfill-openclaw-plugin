{
  "name": "@snapfill/openclaw-plugin",
  "version": "0.1.0",
  "description": "SnapFill tools for OpenClaw",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "src",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
